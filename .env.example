# Port d'écoute du serveur (défaut : 3000)
PORT=3000

# Chemin vers le fichier de données des switchs
# (relatif à la racine du projet)
DATA_FILE=data/switches.json

# Timeout des requêtes vers les switchs (ms)
SWITCH_TIMEOUT=10000

# Ignorer les certificats SSL auto-signés des switchs (recommandé : true)
IGNORE_SSL=true
